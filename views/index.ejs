<%- include('partials/head') %>
<%- include('partials/navbar', { activePage }) %>

<header class="hero-section text-white d-flex align-items-center">
  <div class="container py-5">
    <div class="row align-items-center g-4">
      <div class="col-lg-7">
        <p class="eyebrow mb-2"><%= profile.role %></p>
        <h1 class="display-5 fw-bold mb-3"><%= profile.headline %></h1>
        <p class="lead mb-4"><%= profile.summary %></p>
        <div class="d-flex gap-3 flex-wrap">
          <a href="/projects" class="btn btn-brand btn-lg">View Projects</a>
          <a href="#contact" class="btn btn-outline-light btn-lg">Contact</a>
          <a href="<%= profile.cv.publicUrl %>" class="btn btn-light btn-lg" target="_blank" rel="noreferrer">Download CV</a>
        </div>
      </div>
      <div class="col-lg-5">
        <div class="highlight-card p-4">
          <h2 class="h4 mb-3">Core Stack</h2>
          <div class="d-flex flex-wrap gap-2 mb-3">
            <span class="skill-pill">Node.js</span>
            <span class="skill-pill">Express</span>
            <span class="skill-pill">EJS</span>
            <span class="skill-pill">Bootstrap</span>
            <span class="skill-pill">MySQL</span>
            <span class="skill-pill">Sequelize</span>
          </div>
          <p class="mb-0 small text-white-50">CV: <a class="text-white" href="<%= profile.cv.publicUrl %>" target="_blank" rel="noreferrer"><%= profile.cv.fileName %></a></p>
        </div>
      </div>
    </div>
  </div>
</header>

<main>
  <section class="py-5">
    <div class="container">
      <div class="d-flex justify-content-between align-items-center flex-wrap gap-3 mb-4">
        <h2 class="section-title mb-0">Featured Projects</h2>
        <a class="btn btn-outline-dark" href="/projects">View all</a>
      </div>
      <div class="row g-4">
        <% projects.forEach(project => { %>
          <div class="col-md-6 col-lg-4">
            <article class="project-card h-100">
              <img src="<%= project.image %>" alt="<%= project.imageAlt %>" class="img-fluid rounded-top" />
              <div class="p-4">
                <h3 class="h5"><%= project.title %></h3>
                <p class="text-muted"><%= project.description %></p>
                <a href="<%= project.github %>" target="_blank" rel="noreferrer" class="btn btn-sm btn-dark">GitHub</a>
              </div>
            </article>
          </div>
        <% }) %>
      </div>
    </div>
  </section>

  <section id="contact" class="py-5 bg-soft">
    <div class="container">
      <div class="row justify-content-center">
        <div class="col-lg-8">
          <h2 class="section-title text-center mb-4">Contact Me</h2>

          <div class="contact-card p-4 mb-4">
            <div class="contact-icons d-flex justify-content-center gap-3 gap-md-4">
              <a class="contact-icon-link contact-icon-email" href="mailto:<%= profile.contact.email %>" aria-label="Send email">
                <svg viewBox="0 0 24 24" fill="none" aria-hidden="true">
                  <path d="M4 6h16v12H4z" stroke="currentColor" stroke-width="1.7" />
                  <path d="m4 7 8 6 8-6" stroke="currentColor" stroke-width="1.7" />
                </svg>
                <span class="visually-hidden">Email</span>
              </a>

              <a class="contact-icon-link contact-icon-linkedin" href="<%= profile.contact.linkedin %>" target="_blank" rel="noreferrer" aria-label="Open LinkedIn profile">
                <svg viewBox="0 0 24 24" fill="none" aria-hidden="true">
                  <path d="M7 10v7M7 7.5v.01M12 17v-4.2c0-1.2.8-2 1.9-2 1.1 0 1.8.8 1.8 2V17M4 4h16v16H4z" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" />
                </svg>
                <span class="visually-hidden">LinkedIn</span>
              </a>

              <a class="contact-icon-link contact-icon-github" href="<%= profile.contact.github %>" target="_blank" rel="noreferrer" aria-label="Open GitHub profile">
                <svg viewBox="0 0 24 24" fill="none" aria-hidden="true">
                  <path d="M9 18c-4 1.3-4-2-6-2m12 4v-3.1a2.7 2.7 0 0 0-.8-2c2.6-.3 5.3-1.3 5.3-6a4.6 4.6 0 0 0-1.2-3.1 4.2 4.2 0 0 0-.1-3.1s-1-.3-3.2 1.2a11 11 0 0 0-6 0C6.8 2.4 5.8 2.7 5.8 2.7a4.2 4.2 0 0 0-.1 3.1A4.6 4.6 0 0 0 4.5 9c0 4.7 2.7 5.7 5.3 6a2.7 2.7 0 0 0-.8 2V20" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round" />
                </svg>
                <span class="visually-hidden">GitHub</span>
              </a>
            </div>
          </div>

          <% if (contactStatus === 'success') { %>
            <div class="alert alert-success">Your message was sent successfully. Thank you!</div>
          <% } else if (contactStatus === 'error') { %>
            <div class="alert alert-danger">Please fill in all contact form fields.</div>
          <% } %>

          <form class="contact-card p-4 p-md-5" action="/contact" method="POST">
            <div class="row g-3">
              <div class="col-md-6">
                <label for="name" class="form-label">Name</label>
                <input type="text" class="form-control" id="name" name="name" required />
              </div>
              <div class="col-md-6">
                <label for="email" class="form-label">Email</label>
                <input type="email" class="form-control" id="email" name="email" required />
              </div>
              <div class="col-12">
                <label for="message" class="form-label">Message</label>
                <textarea class="form-control" id="message" name="message" rows="5" required></textarea>
              </div>
              <div class="col-12 d-flex gap-2 flex-wrap">
                <button type="submit" class="btn btn-brand">Send Message</button>
                <a href="<%= profile.cv.publicUrl %>" target="_blank" rel="noreferrer" class="btn btn-outline-dark">View CV</a>
              </div>
            </div>
          </form>
        </div>
      </div>
    </div>
  </section>
</main>

<%- include('partials/footer') %>
<%- include('partials/scripts') %>
